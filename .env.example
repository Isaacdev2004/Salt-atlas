# Salt Atlas (Vite) — copy to `.env` and fill in values. Never commit real secrets.

# Required: Mapbox public access token (pk.*) from https://account.mapbox.com/
VITE_MAPBOX_TOKEN=

# Backend API origin (no trailing slash). Examples:
#   Local: http://localhost:5000
#   Production: https://your-api.example.com
# Leave unset to use same-origin (e.g. API behind reverse proxy on the same host).
VITE_API_URL=

# Optional: override default county vector tileset and source-layer (must match your Mapbox tileset).
# VITE_MAPBOX_TILESET_URL=mapbox://your.tileset-id
# VITE_MAPBOX_COUNTY_SOURCE_LAYER=your-source-layer-name

# Optional: Mapbox GL style URL (defaults to Mapbox Light).
# VITE_MAPBOX_STYLE=mapbox://styles/mapbox/light-v11
