# Salt Atlas API — copy to `.env` in this folder.

# Optional: PostgreSQL connection string. If unset, the API serves data from `data/derived/*.csv` and GeoJSON files.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
#
# Supabase (important on Windows / IPv4-only networks):
# Prefer the "Session pooler" URI from Dashboard → Settings → Database (host like
# aws-0-REGION.pooler.supabase.com, port 6543). The direct host db.PROJECT.supabase.co:5432
# often fails with getaddrinfo ENOTFOUND from Node on Windows.

# Express API port when running node server.js (default 5000). Do NOT set this to 5432 — that is Postgres, not the API.
# PORT=5000

# Optional: require a password for all /api/* routes except /api/auth-status and /api/site-login.
# Set on Render for production; never commit the real value. Optional stronger signing key:
# SITE_PASSWORD=
# SITE_AUTH_SECRET=
# How long the signed browser session lasts (1–366 days, default 30). Same value is exposed to the client as sessionTtlDays.
# SITE_SESSION_DAYS=30

# Regions / POI response cache TTL in milliseconds (default 600000 = 10 minutes)
# API_CACHE_TTL_MS=600000

# USDOT ArcGIS proxy (optional caps; defaults are safe for Mapbox)
# ESRI_NTD_MAX=12000
# ESRI_NTM_MAX=5000
# Esri geometry simplification (degrees); default trims ~90MB payloads to ~10MB. Set 0 to disable.
# ESRI_NTM_MAXALLOWABLE_OFFSET=0.00008
# Round route vertex coords after fetch (0–8 decimals; default 4)
# ESRI_NTM_COORD_DECIMALS=4
# ESRI_FTA_MAX=5000
# Esri query tuning (default sequential pages = 1; raise to 3–4 only if stable)
# ESRI_PARALLEL_PAGES=1
# ESRI_FETCH_TIMEOUT_MS=120000
# ESRI_PAGE_RETRIES=3
# ESRI_CACHE_TTL_MS=21600000
